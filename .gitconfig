[user]
	signingkey = REDACTED
	name = Vince Faller
	email = vdfaller@gmail.com
[commit]
	gpgSign = true
[pull]
	rebase = true
[init]
	defaultBranch = main
[core]
	editor = code --wait
	symlinks = true
	excludesFile = ~/.gitignore
[alias]
	lg=log --graph --pretty=format:\"%C(auto)%h%C(reset) -%C(auto)%d%C(reset) %s %C(dim white)(%cr) %C(dim cyan)<%an>%C(reset)\" --abbrev-commit --date=relative
	st=status
	lgas=!git lg --all --simplify-by-decoration
	lgs=!git lg --simplify-by-decoration
	lga=!git lg --all
	tidy="!git fetch -p && \
		f() { IFS='\n'; \
			for branch in $(git branch -vv | grep ': gone]' | awk '{print $1}'); \
				do git branch -D $branch; \
			done; \
		}; f"
